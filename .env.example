# API URL (also used for push notification endpoints at /push/*)
NEXT_PUBLIC_API_URL=https://app.vbizme.com/api

# VAPID public key from Laravel (required for browser push subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Optional override if push API host differs from NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_PUSH_API_URL=https://app.vbizme.com/api
