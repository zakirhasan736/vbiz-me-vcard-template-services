# API URL
NEXT_PUBLIC_API_URL=

# Push notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@vbizme.com

# When Laravel is ready, point push API to backend host (leave empty to use Next.js /api/push routes)
NEXT_PUBLIC_PUSH_API_URL=https://app.vbizme.com/api
